# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_KEY=""   # optional — uses anon key if empty

# Resend (required for real email delivery)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# Resend inbound webhook signing secret
# Get from: Resend dashboard → Webhooks → your endpoint → Signing Secret
RESEND_WEBHOOK_SECRET=""

# App
NEXT_PUBLIC_APP_URL="https://your-vercel-url.vercel.app"
EMAIL_DOMAIN="yourdomain.com"
NEXT_PUBLIC_EMAIL_DOMAIN="yourdomain.com"

# x402 pay-per-call (OKX.AI ASP)
# Set PAYMENT_REQUIRED=true after registering endpoints in OKX.AI developer portal
PAYMENT_REQUIRED="false"
PAYMENT_WALLET=""          # Your EVM wallet address on X Layer to receive USDT0

# OKX Developer API credentials (required for real x402 payment verification)
# Get from: https://www.okx.com/web3/build/developer-portal
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""

# Set to "true" to use X Layer Testnet (eip155:1952) instead of Mainnet (eip155:196)
OKX_TESTNET="false"

# Webhook security: HMAC-SHA256 secret for signing inbound email events.
# Generate with: openssl rand -hex 32
# Receivers verify: sha256=<hex> in X-AgentMail-Signature header.
WEBHOOK_SECRET=""
